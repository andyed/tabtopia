# macOS (matches .DS_Store in every directory)
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Backups & logs
# *.orig/*.rej live inside src/ after a merge or patch and would otherwise be
# picked up by a packed zip of the extension source.
*.bak
*.orig
*.rej
*.log
*.patch

# Node (if tooling is ever added)
node_modules/

# Playwright E2E artifacts
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# Internal docs — this repo is PUBLIC (github.com/andyed/tabtopia).
# Strategy and audit docs stay on local disk: they carry positioning, and they
# enumerate open findings with file:line, which is not something to publish
# while those findings are open.
/docs/PRODUCT_CASE.md
/docs/HEALTHCHECK_*.md
/docs/AUDIT.md
/docs/MCP_ARCHITECTURE.md

# Reference papers — third-party copyrighted PDFs. Keep locally, cite by DOI;
# do not redistribute from a public repo.
/references/
