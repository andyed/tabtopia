# macOS (matches .DS_Store in every directory)
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*~

# Backups & logs
# *.orig/*.rej live inside src/ after a merge or patch and would otherwise be
# picked up by a packed zip of the extension source.
*.bak
*.orig
*.rej
*.log
*.patch

# Node (if tooling is ever added)
node_modules/

# Playwright E2E artifacts
/test-results/
/playwright-report/
/blob-report/
/.playwright/
